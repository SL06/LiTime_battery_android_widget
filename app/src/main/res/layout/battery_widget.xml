<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@android:style/Widget"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#484848"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_status"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:textSize="14sp" />

    <!-- Cercle indicateur de charge -->
    <ImageView
        android:id="@+id/widget_indicator"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_toEndOf="@id/widget_title"
        android:layout_alignTop="@id/widget_title"
        android:layout_alignBottom="@id/widget_title"
        android:layout_marginStart="8dp"
        android:src="@android:drawable/presence_online"
        android:contentDescription="@null" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0" />

    <LinearLayout
        android:id="@+id/data_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_progress"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Niveau: --%"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/widget_watts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watts: --"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/widget_capacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cap: -- Ah"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temp: --°C"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/widget_volt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V/A: --"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_graph"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/data_container"
        android:layout_marginTop="4dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/widget_graph_description" />

    <TextView
        android:id="@+id/widget_last_update"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_graph"
        android:text="MàJ: --:--"
        android:textColor="#BBBBBB"
        android:textSize="9sp"
        android:gravity="end"
        android:layout_marginTop="2dp" />

</RelativeLayout>
